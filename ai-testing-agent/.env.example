# ============================================================
# AI Testing Agent - 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的 API Key 和配置
#   3. .env 文件已被 .gitignore 忽略，不会提交到仓库

# ============================================================
# DeepSeek（默认模型）
# ============================================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL_NAME=deepseek-chat

# ============================================================
# 豆包/火山引擎（Vision 多模态）
# ============================================================
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL_NAME=doubao-seed-2-0-lite-260215
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ============================================================
# 通义千问（Qwen）
# ============================================================
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL_NAME=qwen-turbo

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# Kimi / Moonshot
# ============================================================
MOONSHORT_API_KEY=your_moonshot_api_key_here
MOONSHORT_BASE_URL=https://api.moonshot.cn/v1
MOONSHORT_MODEL_NAME=kimi-k2.5

# ============================================================
# Google Gemini
# ============================================================
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL_NAME=gemini-1.5-flash

# ============================================================
# 小米 MIMO
# ============================================================
XIAOMI_API_KEY=your_xiaomi_api_key_here
XIAOMI_MODEL_NAME=mimo-v2-pro
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1/

# ============================================================
# 本地模型（Ollama）
# ============================================================
LOCAL_MODEL_NAME=qwen3.5:0.8b
LOCAL_BASE_URL=http://127.0.0.1:11434

# ============================================================
# 智谱 GLM
# ============================================================
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL_NAME=glm-4.7

# ============================================================
# Tavily 搜索（用于网络搜索工具）
# ============================================================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================
# 服务配置
# ============================================================
# 后端服务端口（可选，默认见 start_server.py）
# SERVER_PORT=8000
# SERVER_HOST=127.0.0.1

# ============================================================
# 存储配置（可选，生产环境使用）
# ============================================================
# 附件保存目录（默认: 系统临时目录/agent_files）
# ATTACHMENT_SAVE_DIR=./uploads

# 腾讯云 COS 对象存储（生产环境推荐）
# COS_SECRET_ID=your_cos_secret_id
# COS_SECRET_KEY=your_cos_secret_key
# COS_BUCKET=your_bucket_name
# COS_REGION=ap-shanghai
